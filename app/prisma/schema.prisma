generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("STUDENT")
  password      String?
  hourlyRate    Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  students       Student[] @relation("CoachStudents")
  studentProfile Student?  @relation("StudentUser")
  parentOf       Student[] @relation("ParentStudents")
  lessonTemplates LessonTemplate[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Student {
  id         String   @id @default(cuid())
  name       String
  age        Int?
  rating     Int      @default(0)
  skillLevel String   @default("beginner")
  goals      String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  coachId String
  coach   User   @relation("CoachStudents", fields: [coachId], references: [id])

  userId String? @unique
  user   User?   @relation("StudentUser", fields: [userId], references: [id])

  parentId String?
  parent   User?   @relation("ParentStudents", fields: [parentId], references: [id])

  context           StudentContext?
  coachSessions     CoachSession[]
  gameAnalyses      GameAnalysis[]
  snapshots         ProgressSnapshot[]
  plans             ImprovementPlan[]
  parentReports     ParentReport[]
  homeworkAssignments Homework[]
  scheduledSessions ScheduledSession[]
  billingEntries    BillingEntry[]
}

model StudentContext {
  id             String   @id @default(cuid())
  studentId      String   @unique
  contextSummary String   @default("")
  rawNotesBuffer String   @default("[]")
  updatedAt      DateTime @updatedAt
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model CoachSession {
  id              String   @id @default(cuid())
  studentId       String
  date            DateTime @default(now())
  duration        Int      @default(60)
  topicsCovered   String?
  coachNotes      String?
  wellness        String?
  aiSummary       String?
  homeworkSet     String?
  nextSessionDate DateTime?
  lessonTemplateId String?
  createdAt       DateTime @default(now())
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model ScheduledSession {
  id          String   @id @default(cuid())
  studentId   String
  scheduledAt DateTime
  duration    Int      @default(60)
  status      String   @default("PENDING")
  notes       String?
  createdAt   DateTime @default(now())
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Homework {
  id          String    @id @default(cuid())
  studentId   String
  title       String
  description String?
  resourceUrl String?
  dueDate     DateTime?
  status      String    @default("PENDING")
  completedAt DateTime?
  studentNote String?
  createdAt   DateTime  @default(now())
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model LessonTemplate {
  id          String   @id @default(cuid())
  coachId     String
  title       String
  skillLevel  String   @default("all")
  topics      String
  description String?
  duration    Int      @default(60)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  coach       User     @relation(fields: [coachId], references: [id], onDelete: Cascade)
}

model GameAnalysis {
  id               String   @id @default(cuid())
  studentId        String
  pgn              String
  result           String?
  aiAnalysis       String?
  patternsDetected String   @default("[]")
  createdAt        DateTime @default(now())
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model ProgressSnapshot {
  id              String   @id @default(cuid())
  studentId       String
  month           DateTime
  rating          Int
  topicMastery    String   @default("{}")
  improvementRate Float    @default(0)
  sessionCount    Int      @default(0)
  createdAt       DateTime @default(now())
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, month])
}

model ImprovementPlan {
  id         String   @id @default(cuid())
  studentId  String
  topics     String   @default("[]")
  milestones String   @default("[]")
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model ParentReport {
  id        String    @id @default(cuid())
  studentId String
  month     DateTime
  content   String
  status    String    @default("DRAFT")
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model BillingEntry {
  id        String   @id @default(cuid())
  studentId String
  month     DateTime
  sessions  Int      @default(0)
  hours     Float    @default(0)
  rateUsed  Float    @default(0)
  amount    Float    @default(0)
  paid      Boolean  @default(false)
  paidAt    DateTime?
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, month])
}

model Message {
  id         String    @id @default(cuid())
  fromUserId String
  toUserId   String
  body       String
  readAt     DateTime?
  createdAt  DateTime  @default(now())
}
