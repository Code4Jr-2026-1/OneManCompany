generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("STUDENT")
  password      String?
  hourlyRate         Float?
  upiId              String?
  defaultMeetingLink String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  students        Student[]       @relation("CoachStudents")
  studentProfile  Student?        @relation("StudentUser")
  parentOf        Student[]       @relation("ParentStudents")
  lessonTemplates LessonTemplate[]
  groupClasses    GroupClass[]
  studentInvites  StudentInvite[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Student {
  id         String   @id @default(cuid())
  name       String
  age        Int?
  rating     Int      @default(0)
  skillLevel String   @default("beginner")
  goals      String?
  notes      String?
  phone      String?
  email      String?
  lichessId  String?
  fideId     String?
  aicfId     String?
  stateId    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  weakness     String?
  billingType  String  @default("hourly")
  monthlyFee   Float?

  coachId String
  coach   User   @relation("CoachStudents", fields: [coachId], references: [id])

  userId String? @unique
  user   User?   @relation("StudentUser", fields: [userId], references: [id])

  parentId String?
  parent   User?   @relation("ParentStudents", fields: [parentId], references: [id])

  context             StudentContext?
  coachSessions       CoachSession[]
  gameAnalyses        GameAnalysis[]
  snapshots           ProgressSnapshot[]
  plans               ImprovementPlan[]
  parentReports       ParentReport[]
  homeworkAssignments Homework[]
  scheduledSessions   ScheduledSession[]
  billingEntries      BillingEntry[]
  groupEnrollments    GroupEnrollment[]
}

model StudentContext {
  id             String   @id @default(cuid())
  studentId      String   @unique
  contextSummary String   @default("")
  rawNotesBuffer String   @default("[]")
  updatedAt      DateTime @updatedAt
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model CoachSession {
  id              String   @id @default(cuid())
  studentId       String
  date            DateTime @default(now())
  duration        Int      @default(60)
  topicsCovered   String?
  coachNotes      String?
  wellness        String?
  transcript      String?
  aiSummary       String?
  aiAnalysis      String?
  homeworkSet     String?
  nextSessionDate DateTime?
  lessonTemplateId String?
  createdAt       DateTime @default(now())
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model ScheduledSession {
  id               String   @id @default(cuid())
  studentId        String
  scheduledAt      DateTime
  duration         Int      @default(60)
  status           String   @default("PENDING")
  notes            String?
  meetingLink      String?
  reminder24hSent  Boolean  @default(false)
  reminder1hSent   Boolean  @default(false)
  createdAt        DateTime @default(now())
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Homework {
  id           String     @id @default(cuid())
  studentId    String
  groupClassId String?
  title        String
  description  String?
  resourceUrl  String?
  dueDate      DateTime?
  status       String     @default("PENDING")
  completedAt  DateTime?
  studentNote  String?
  createdAt    DateTime   @default(now())
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  groupClass   GroupClass? @relation(fields: [groupClassId], references: [id], onDelete: SetNull)
}

model LessonTemplate {
  id          String   @id @default(cuid())
  coachId     String
  title       String
  skillLevel  String   @default("all")
  topics      String
  description String?
  duration    Int      @default(60)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  coach       User     @relation(fields: [coachId], references: [id], onDelete: Cascade)
}

model GameAnalysis {
  id               String   @id @default(cuid())
  studentId        String
  pgn              String
  result           String?
  aiAnalysis       String?
  patternsDetected String   @default("[]")
  createdAt        DateTime @default(now())
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model ProgressSnapshot {
  id              String   @id @default(cuid())
  studentId       String
  month           DateTime
  rating          Int
  topicMastery    String   @default("{}")
  improvementRate Float    @default(0)
  sessionCount    Int      @default(0)
  createdAt       DateTime @default(now())
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, month])
}

model ImprovementPlan {
  id         String   @id @default(cuid())
  studentId  String
  topics     String   @default("[]")
  milestones String   @default("[]")
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model ParentReport {
  id        String    @id @default(cuid())
  studentId String
  month     DateTime
  content   String
  status    String    @default("DRAFT")
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model BillingEntry {
  id           String      @id @default(cuid())
  studentId    String
  groupClassId String?
  month        DateTime
  sessions     Int         @default(0)
  hours        Float       @default(0)
  rateUsed     Float       @default(0)
  amount       Float       @default(0)
  paid         Boolean     @default(false)
  paidAt       DateTime?
  createdAt    DateTime    @default(now())
  student      Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  groupClass   GroupClass? @relation(fields: [groupClassId], references: [id], onDelete: SetNull)
}

model Message {
  id         String    @id @default(cuid())
  fromUserId String
  toUserId   String
  body       String
  readAt     DateTime?
  createdAt  DateTime  @default(now())
}

model GroupClass {
  id                String   @id @default(cuid())
  coachId           String
  name              String
  description       String?
  skillLevel        String   @default("all")
  capacity          Int      @default(10)
  dayOfWeek         Int
  startTime         String
  duration          Int      @default(60)
  groupRate         Float    @default(0)
  isActive          Boolean  @default(true)
  meetingLink       String?
  whatsappGroupLink String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  coach       User               @relation(fields: [coachId], references: [id], onDelete: Cascade)
  enrollments GroupEnrollment[]
  sessions    GroupSession[]
  homework    Homework[]
  billingEntries BillingEntry[]
}

model GroupEnrollment {
  id           String     @id @default(cuid())
  groupClassId String
  studentId    String
  status       String     @default("ACTIVE")
  enrolledAt   DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  groupClass   GroupClass @relation(fields: [groupClassId], references: [id], onDelete: Cascade)
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupClassId, studentId])
}

model GroupSession {
  id            String     @id @default(cuid())
  groupClassId  String
  date          DateTime
  topicsCovered String?
  coachNotes    String?
  aiSummary     String?
  createdAt     DateTime   @default(now())

  groupClass    GroupClass @relation(fields: [groupClassId], references: [id], onDelete: Cascade)
}

model StudentInvite {
  id          String   @id @default(cuid())
  token       String   @unique
  coachId     String
  status      String   @default("PENDING")
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  submittedAt DateTime?

  name       String?
  age        Int?
  phone      String?
  email      String?
  skillLevel String?
  goals      String?
  lichessId  String?
  fideId     String?
  aicfId     String?
  stateId    String?

  studentId String?

  coach User @relation(fields: [coachId], references: [id], onDelete: Cascade)
}
